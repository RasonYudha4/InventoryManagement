@page "/"
@using InventoryManagement.UI.Models
@using InventoryManagement.UI.Services
@using InventoryManagement.UI.Services.Interfaces
@inject IStockService StockService

<PageTitle>Inventory Dashboard</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">Warehouse Overview</h2>

    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">🚨 Low Stock Alerts</h5>
        </div>
        <div class="card-body">
            @if (_isLoading)
            {
                <p><em>Loading live data from Azure...</em></p>
            }
            else if (!_lowStockItems.Any())
            {
                <div class="alert alert-success">All inventory levels are looking good!</div>
            }
            else
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>SKU</th>
                            <th>Product Name</th>
                            <th>Current Qty</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _lowStockItems)
                        {
                            <tr>
                                <td><strong>@item.ProductName</strong></td>
                                <td>@item.CurrentQuantity</td>
                                <td>@item.ReorderPoint</td>
                                <td><span class="badge bg-warning text-dark">Needs Reorder</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private List<LowStockItemDto> _lowStockItems = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // This fires the second the page loads
        _lowStockItems = await StockService.GetLowStockItemsAsync();
        _isLoading = false;
    }
}