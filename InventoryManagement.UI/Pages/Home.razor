@page "/"
@attribute [Authorize] 
<PageTitle>Warehouse Dashboard</PageTitle>

<h1>Welcome to the Warehouse Dashboard</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Active Products</h5>
                <p class="card-text display-4">142</p> </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Low Stock Alerts</h5>
                <p class="card-text display-4">3</p> 
            </div>
        </div>
    </div>
</div>