@page "/stock/dispatch"
@using System.ComponentModel.DataAnnotations
@using InventoryManagement.UI.Models.Requests
@attribute [Authorize(Roles = "Admin,Manager,WarehouseStaff")]
@inject IStockService StockService
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject ISalesOrderService SalesOrderService

<PageTitle>Dispatch Stock — Inventory</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Dispatch Stock</h1>
        <p class="page-subtitle">Record outgoing inventory against a sales order</p>
    </div>
</div>

@if (_successMessage is not null)
{
    <div class="alert-success">
        <span class="bi bi-check-circle-fill"></span> @_successMessage
    </div>
}

@if (_error is not null)
{
    <div class="alert-error">
        <span class="bi bi-exclamation-circle-fill"></span> @_error
    </div>
}

<div class="form-card">
    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Sales Order <span class="required">*</span></label>
                <select class="form-select" @onchange="OnSalesOrderChanged" disabled="@_loadingSalesOrders">
                    <option value="">— Select sales order —</option>
                    @foreach (var so in _salesOrders)
                    {
                        <option value="@so.Id">@so.SONumber — @so.CustomerName</option>
                    }
                </select>
                <ValidationMessage For="() => _model.SalesOrderId" />
            </div>

            <div class="form-group">
                <label class="form-label">Product <span class="required">*</span></label>
                <select class="form-select" @bind="_model.ProductId" disabled="@(!_soLines.Any())">
                    <option value="">— Select product —</option>
                    @foreach (var line in _soLines)
                    {
                        <option value="@line.ProductId">
                            @line.ProductName (@line.SKU) — @(line.OrderedQuantity - line.DispatchedQuantity) remaining
                        </option>
                    }
                </select>
                <ValidationMessage For="() => _model.ProductId" />
            </div>

            <div class="form-group">
                <label class="form-label">Warehouse <span class="required">*</span></label>
                <select class="form-select" @onchange="OnWarehouseChanged" disabled="@_loadingWarehouses">
                    <option value="">— Select warehouse —</option>
                    @foreach (var wh in _warehouses)
                    {
                        <option value="@wh.Id">@wh.Name (@wh.Code)</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Location <span class="required">*</span></label>
                <select class="form-select" @bind="_model.LocationId" disabled="@(!_locations.Any())">
                    <option value="">— Select location —</option>
                    @foreach (var loc in _locations)
                    {
                        <option value="@loc.Id">@loc.Code</option>
                    }
                </select>
                <ValidationMessage For="() => _model.LocationId" />
            </div>

            <div class="form-group">
                <label class="form-label">Quantity <span class="required">*</span></label>
                <InputNumber class="form-input" @bind-Value="_model.Quantity" min="1" />
                <ValidationMessage For="() => _model.Quantity" />
            </div>

            <div class="form-group form-group-full">
                <label class="form-label">Notes</label>
                <InputTextArea class="form-input form-textarea" @bind-Value="_model.Notes" rows="3"
                               placeholder="Optional dispatch notes..." />
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn-secondary" @onclick="Reset" disabled="@_submitting">Reset</button>
            <button type="submit" class="btn-primary btn-danger-action" disabled="@_submitting">
                @if (_submitting)
                {
                    <span class="spinner-sm"></span> <span>Dispatching...</span>
                }
                else
                {
                    <span class="bi bi-arrow-up-square"></span> <span>Dispatch Stock</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    private DispatchStockFormModel _model = new();
    private List<SalesOrderSummaryDto> _salesOrders = [];
    private List<SalesOrderLineDetailDto> _soLines = [];
    private List<WarehouseDto> _warehouses = [];
    private List<LocationDto> _locations = [];

    private bool _loadingSalesOrders = true;
    private bool _loadingWarehouses = true;
    private bool _submitting;
    private string? _error;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var salesOrdersTask = SalesOrderService.GetAllSalesOrdersAsync();
            var warehousesTask = WarehouseService.GetAllWarehousesAsync();
            await Task.WhenAll(salesOrdersTask, warehousesTask);

            // Only show confirmed or partially dispatched SOs
            _salesOrders = salesOrdersTask.Result
                .Where(so => so.Status == "Confirmed" || so.Status == "PartiallyDispatched")
                .ToList();

            _warehouses = warehousesTask.Result;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load form data: {ex.Message}";
        }
        finally
        {
            _loadingSalesOrders = false;
            _loadingWarehouses = false;
        }
    }

    private async Task OnSalesOrderChanged(ChangeEventArgs e)
    {
        _soLines = [];
        _model.SalesOrderId = Guid.Empty;
        _model.ProductId = Guid.Empty;

        if (Guid.TryParse(e.Value?.ToString(), out var soId))
        {
            try
            {
                var so = await SalesOrderService.GetSalesOrderByIdAsync(soId);

                // Only show lines that still have items left to dispatch
                _soLines = so.OrderLines
                    .Where(l => l.OrderedQuantity - l.DispatchedQuantity > 0)
                    .ToList();

                _model.SalesOrderId = soId;
            }
            catch (Exception ex)
            {
                _error = $"Failed to load sales order lines: {ex.Message}";
            }
        }
    }

    private void OnWarehouseChanged(ChangeEventArgs e)
    {
        _locations = [];
        _model.LocationId = string.Empty;

        if (Guid.TryParse(e.Value?.ToString(), out var warehouseId))
        {
            var warehouse = _warehouses.FirstOrDefault(w => w.Id == warehouseId);
            _locations = warehouse?.Locations ?? [];
        }
    }

    private async Task HandleSubmit()
    {
        _submitting = true;
        _error = null;
        _successMessage = null;

        try
        {
            if (_model.SalesOrderId == Guid.Empty)
                throw new Exception("Please select a sales order.");

            if (_model.ProductId == Guid.Empty)
                throw new Exception("Please select a product.");

            if (!Guid.TryParse(_model.LocationId, out var locationId))
                throw new Exception("Please select a location.");

            var soLine = _soLines.FirstOrDefault(l => l.ProductId == _model.ProductId);
            var soNumber = _salesOrders.FirstOrDefault(so => so.Id == _model.SalesOrderId)?.SONumber;

            var request = new DispatchStockRequest(
                _model.ProductId,
                locationId,
                _model.SalesOrderId,
                _model.Quantity,
                _model.Notes
            );

            var transactionId = await StockService.DispatchStockAsync(request);
            _successMessage = $"Stock dispatched successfully. Transaction ID: {transactionId}";
            Reset();
        }
        catch (Exception ex)
        {
            _error = $"Failed to dispatch stock: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Reset()
    {
        _model = new();
        _soLines = [];
        _locations = [];
    }

    private class DispatchStockFormModel
    {
        public Guid SalesOrderId { get; set; }
        [Required] public Guid ProductId { get; set; }
        [Required] public string LocationId { get; set; } = string.Empty;
        [Range(1, int.MaxValue, ErrorMessage = "Quantity must be at least 1.")]
        public int Quantity { get; set; } = 1;
        public string? Notes { get; set; }
    }
}