@page "/stock/receive"
@using InventoryManagement.UI.Models.Requests
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Roles = "Admin,Manager,WarehouseStaff")]
@inject IStockService StockService
@inject IWarehouseService WarehouseService
@inject IProductService ProductService
@inject IPurchaseOrderService PurchaseOrderService
@inject NavigationManager Nav

<PageTitle>Receive Stock — Inventory</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Receive Stock</h1>
        <p class="page-subtitle">Record incoming inventory against a purchase order</p>
    </div>
</div>

@if (_successMessage is not null)
{
    <div class="alert-success">
        <span class="bi bi-check-circle-fill"></span> @_successMessage
    </div>
}

@if (_error is not null)
{
    <div class="alert-error">
        <span class="bi bi-exclamation-circle-fill"></span> @_error
    </div>
}

<div class="form-card">
    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Purchase Order <span class="required">*</span></label>
                <select class="form-select" @onchange="OnPurchaseOrderChanged" disabled="@_loadingPurchaseOrders">
                    <option value="">— Select purchase order —</option>
                    @foreach (var po in _purchaseOrders)
                    {
                        <option value="@po.Id">@po.PONumber — @po.SupplierName</option>
                    }
                </select>
                <ValidationMessage For="() => _model.PurchaseOrderId" />
            </div>

            <div class="form-group">
                <label class="form-label">Product <span class="required">*</span></label>
                <select class="form-select" @bind="_model.ProductId" disabled="@(!_poLines.Any())">
                    <option value="">— Select product —</option>
                    @foreach (var line in _poLines)
                    {
                        <option value="@line.ProductId">@line.ProductName (@line.SKU) — @(line.OrderedQuantity - line.ReceivedQuantity) remaining</option>
                    }
                </select>
                <ValidationMessage For="() => _model.ProductId" />
            </div>

            <div class="form-group">
                <label class="form-label">Warehouse <span class="required">*</span></label>
                <select class="form-select" @onchange="OnWarehouseChanged" disabled="@_loadingWarehouses">
                    <option value="">— Select warehouse —</option>
                    @foreach (var wh in _warehouses)
                    {
                        <option value="@wh.Id">@wh.Name (@wh.Code)</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Location <span class="required">*</span></label>
                <select class="form-select" @bind="_model.LocationId" disabled="@(!_locations.Any())">
                    <option value="">— Select location —</option>
                    @foreach (var loc in _locations)
                    {
                        <option value="@loc.Id">@loc.Code</option>
                    }
                </select>
                <ValidationMessage For="() => _model.LocationId" />
            </div>

            <div class="form-group">
                <label class="form-label">Quantity <span class="required">*</span></label>
                <InputNumber class="form-input" @bind-Value="_model.Quantity" min="1" />
                <ValidationMessage For="() => _model.Quantity" />
            </div>

            <div class="form-group form-group-full">
                <label class="form-label">Notes</label>
                <InputTextArea class="form-input form-textarea" @bind-Value="_model.Notes" rows="3"
                               placeholder="Optional notes about this receipt..." />
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn-secondary" @onclick="Reset" disabled="@_submitting">
                Reset
            </button>
            <button type="submit" class="btn-primary" disabled="@_submitting">
                @if (_submitting)
                {
                    <span class="spinner-sm"></span> <span>Receiving...</span>
                }
                else
                {
                    <span class="bi bi-arrow-down-square"></span> <span>Receive Stock</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    private ReceiveStockFormModel _model = new();
    private List<PurchaseOrderSummaryDto> _purchaseOrders = [];
    private List<PurchaseOrderLineDetailDto> _poLines = [];
    private List<WarehouseDto> _warehouses = [];
    private List<LocationDto> _locations = [];

    private bool _loadingPurchaseOrders = true;
    private bool _loadingWarehouses = true;
    private bool _submitting;
    private string? _error;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var purchaseOrdersTask = PurchaseOrderService.GetAllPurchaseOrdersAsync();
            var warehousesTask = WarehouseService.GetAllWarehousesAsync();
            await Task.WhenAll(purchaseOrdersTask, warehousesTask);

            // Only show approved POs that still have remaining items to receive
            _purchaseOrders = purchaseOrdersTask.Result
                .Where(po => po.Status == "Approved" || po.Status == "PartiallyReceived")
                .ToList();

            _warehouses = warehousesTask.Result;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load form data: {ex.Message}";
        }
        finally
        {
            _loadingPurchaseOrders = false;
            _loadingWarehouses = false;
        }
    }

    private async Task OnPurchaseOrderChanged(ChangeEventArgs e)
    {
        _poLines = [];
        _model.PurchaseOrderId = Guid.Empty;
        _model.ProductId = Guid.Empty;

        if (Guid.TryParse(e.Value?.ToString(), out var poId))
        {
            try
            {
                var po = await PurchaseOrderService.GetPurchaseOrderByIdAsync(poId);
                _poLines = po.OrderLines
                    .Where(l => l.OrderedQuantity - l.ReceivedQuantity > 0)
                    .ToList();

                _model.PurchaseOrderId = poId;
            }
            catch (Exception ex)
            {
                _error = $"Failed to load purchase order lines: {ex.Message}";
            }
        }
    }

    private void OnWarehouseChanged(ChangeEventArgs e)
    {
        _locations = [];
        _model.LocationId = string.Empty;

        if (Guid.TryParse(e.Value?.ToString(), out var warehouseId))
        {
            var warehouse = _warehouses.FirstOrDefault(w => w.Id == warehouseId);
            _locations = warehouse?.Locations ?? [];
        }
    }

    private async Task HandleSubmit()
    {
        _submitting = true;
        _error = null;
        _successMessage = null;

        try
        {
            if (_model.PurchaseOrderId == Guid.Empty)
                throw new Exception("Please select a purchase order.");

            if (!Guid.TryParse(_model.LocationId, out var locationId))
                throw new Exception("Please select a location.");

            var request = new ReceiveStockRequest(
                _model.ProductId,
                locationId,
                _model.PurchaseOrderId,
                _model.Quantity,
                _model.Notes
            );

            var transactionId = await StockService.ReceiveStockAsync(request);
            _successMessage = $"Stock received successfully. Transaction ID: {transactionId}";
            Reset();
        }
        catch (Exception ex)
        {
            _error = $"Failed to receive stock: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Reset()
    {
        _model = new();
        _poLines = [];
        _locations = [];
    }

    private class ReceiveStockFormModel
    {
        [Required] public Guid PurchaseOrderId { get; set; }
        [Required] public Guid ProductId { get; set; }
        [Required] public string LocationId { get; set; } = string.Empty;
        [Range(1, int.MaxValue, ErrorMessage = "Quantity must be at least 1.")]
        public int Quantity { get; set; } = 1;
        public string? Notes { get; set; }
    }
}