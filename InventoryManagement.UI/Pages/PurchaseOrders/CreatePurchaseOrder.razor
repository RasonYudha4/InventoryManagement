@page "/purchase-orders/create"
@using InventoryManagement.UI.Models.Requests
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Roles = "Admin,Manager")]
@inject IPurchaseOrderService PurchaseOrderService
@inject ISupplierService SupplierService
@inject IProductService ProductService
@inject NavigationManager Nav
@inject ILogger<object> Logger

<PageTitle>New Purchase Order — Inventory</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <a href="/purchase-orders" class="btn-back"><span class="bi bi-arrow-left"></span> Purchase Orders</a>
        <div>
            <h1 class="page-title">New Purchase Order</h1>
            <p class="page-subtitle">Create a draft order to send to a supplier</p>
        </div>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert-error">
        <span class="bi bi-exclamation-circle-fill"></span> @_error
    </div>
}

@* Debug panel — remove before production *@
@if (_debugLog.Any())
{
    <div class="alert-info" style="font-family: monospace; font-size: 0.8rem; white-space: pre-wrap;">
        <strong>Debug Log:</strong>
        @foreach (var entry in _debugLog)
        {
            <div>@entry</div>
        }
    </div>
}

<div class="form-card">
    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <h2 class="form-section-title">Order Details</h2>
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Supplier <span class="required">*</span></label>
                <select class="form-select" @bind="_model.SupplierId" disabled="@_loadingSuppliers">
                    <option value="">— Select supplier —</option>
                    @foreach (var s in _suppliers)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
                <ValidationMessage For="() => _model.SupplierId" />
            </div>

            <div class="form-group form-group-full">
                <label class="form-label">Notes</label>
                <InputTextArea class="form-input form-textarea" @bind-Value="_model.Notes"
                               rows="3" placeholder="Optional notes for this purchase order..." />
            </div>
        </div>

        <h2 class="form-section-title">
            Order Lines
            <span class="section-badge">@_model.Items.Count item(s)</span>
        </h2>

        @if (_model.Items.Any())
        {
            <div class="data-card">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Product ID</th>
                            <th class="col-num">Quantity</th>
                            <th class="col-num">Unit Cost</th>
                            <th>Expected Delivery</th>
                            <th class="col-num">Line Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < _model.Items.Count; i++)
                        {
                            var index = i;
                            var item = _model.Items[index];
                            <tr>
                                <td class="col-mono">@item.ProductId</td>
                                <td class="col-num">@item.Quantity</td>
                                <td class="col-num">@item.NegotiatedUnitCost.ToString("C")</td>
                                <td>@(item.ExpectedDeliveryDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td class="col-num">@((item.Quantity * item.NegotiatedUnitCost).ToString("C"))</td>
                                <td class="col-actions">
                                    <button type="button" class="btn-link btn-danger-text"
                                            @onclick="() => RemoveItem(index)">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-footer">
                            <td colspan="3" class="col-num">Estimated Total</td>
                            <td class="col-num col-primary">@_estimatedTotal.ToString("C")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }

        <div class="line-item-form">
            <h3 class="line-item-title">Add Line Item</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Product <span class="required">*</span></label>
                    <select class="form-select" @bind="_newItem.ProductId" disabled="@_loadingDropdowns">
                        <option value="">— Select product —</option>
                        @foreach (var p in _products)
                        {
                            <option value="@p.Id">@p.Name (@p.SKU)</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Quantity <span class="required">*</span></label>
                    <InputNumber class="form-input" @bind-Value="_newItem.Quantity" min="1" />
                </div>

                <div class="form-group">
                    <label class="form-label">Negotiated Unit Cost <span class="required">*</span></label>
                    <div class="input-prefix-group">
                        <span class="input-prefix">$</span>
                        <InputNumber class="form-input" @bind-Value="_newItem.NegotiatedUnitCost"
                                     min="0" step="0.01" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Expected Delivery</label>
                    <InputDate class="form-input" @bind-Value="_newItem.ExpectedDeliveryDate" />
                </div>

                <div class="form-group form-group-align-end">
                    <button type="button" class="btn-secondary" @onclick="AddItem"
                            disabled="@(!CanAddItem)">
                        <span class="bi bi-plus-lg"></span> Add Line
                    </button>
                </div>
            </div>

            @if (_lineItemError is not null)
            {
                <p class="form-error-inline">@_lineItemError</p>
            }
        </div>

        <div class="form-actions">
            <a href="/purchase-orders" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn-primary" disabled="@_submitting">
                @if (_submitting)
                {
                    <span class="spinner-sm"></span> <span>Creating Draft...</span>
                }
                else
                {
                    <span class="bi bi-file-earmark-plus"></span> <span>Create Draft</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    private CreatePurchaseOrderFormModel _model = new();
    private LineItemFormModel _newItem = new();
    private bool _submitting;
    private string? _error;
    private string? _lineItemError;
    private List<SupplierSummaryDto> _suppliers = [];
    private List<ProductSummaryDto> _products = [];
    private bool _loadingSuppliers = true;
    private bool _loadingDropdowns = true;
    private List<string> _debugLog = [];

    protected override async Task OnInitializedAsync()
    {
        Log("OnInitializedAsync started.");
        try
        {
            var suppliersTask = SupplierService.GetAllSuppliersAsync();
            var productsTask  = ProductService.GetAllProductsAsync();
            await Task.WhenAll(suppliersTask, productsTask);

            _suppliers = suppliersTask.Result;
            _products  = productsTask.Result;

            Log($"Loaded {_suppliers.Count} supplier(s), {_products.Count} product(s).");
        }
        catch (Exception ex)
        {
            _error = $"Failed to load form data: {ex.Message}";
            Log($"ERROR during init: {ex.Message}");
            Logger.LogError(ex, "Failed to load PO form data.");
        }
        finally
        {
            _loadingSuppliers = false;
            _loadingDropdowns = false;
            Log("Dropdowns unlocked.");
        }
    }

    private decimal _estimatedTotal =>
        _model.Items.Sum(i => i.Quantity * i.NegotiatedUnitCost);

    private bool CanAddItem =>
        !string.IsNullOrWhiteSpace(_newItem.ProductId) &&
        _newItem.Quantity > 0 &&
        _newItem.NegotiatedUnitCost > 0;

    private void AddItem()
    {
        _lineItemError = null;
        Log($"AddItem called — ProductId='{_newItem.ProductId}', Qty={_newItem.Quantity}, Cost={_newItem.NegotiatedUnitCost}, CanAddItem={CanAddItem}");

        if (!CanAddItem)
        {
            _lineItemError = "Please fill in all line item fields before adding.";
            Log("AddItem blocked: CanAddItem is false.");
            return;
        }

        if (_model.Items.Any(i => i.ProductId == _newItem.ProductId))
        {
            _lineItemError = "This product is already in the order. Adjust the existing line instead.";
            Log($"AddItem blocked: duplicate ProductId '{_newItem.ProductId}'.");
            return;
        }

        _model.Items.Add(new LineItemFormModel
        {
            ProductId            = _newItem.ProductId,
            Quantity             = _newItem.Quantity,
            NegotiatedUnitCost   = _newItem.NegotiatedUnitCost
        });

        Log($"Item added. Total items now: {_model.Items.Count}. Estimated total: {_estimatedTotal:C}");
        _newItem = new();
    }

    private void RemoveItem(int index)
    {
        Log($"RemoveItem called at index {index}. Items before: {_model.Items.Count}");
        if (index >= 0 && index < _model.Items.Count)
        {
            _model.Items.RemoveAt(index);
            Log($"Item removed. Items remaining: {_model.Items.Count}");
        }
        else
        {
            Log($"RemoveItem: index {index} out of range.");
        }
    }

    private async Task HandleSubmit()
    {
        _submitting = true;
        _error = null;
        _lineItemError = null;

        Log($"HandleSubmit called. SupplierId='{_model.SupplierId}', Items={_model.Items.Count}, HasPartialInput={HasPartialInput}");

        try
        {
            // Validate supplier
            if (!Guid.TryParse(_model.SupplierId, out var supplierId))
            {
                _error = "Please select a supplier.";
                _submitting = false;
                return;
            }

            // Warn if sub-form has unsaved data
            if (HasPartialInput)
            {
                _lineItemError = "You have an unsaved line item — click Add Line first, or clear the fields.";
                _submitting = false;
                return;
            }

            // Validate at least one line item exists
            if (!_model.Items.Any())
            {
                _lineItemError = "Please add at least one line item before creating the order.";
                _submitting = false;
                return;
            }

            var request = new CreatePurchaseOrderRequest(
                supplierId,
                _model.Notes,
                _model.Items.Select(i => new PurchaseOrderLineItemRequest(
                    Guid.Parse(i.ProductId),
                    i.Quantity,
                    i.NegotiatedUnitCost,
                    i.ExpectedDeliveryDate
                )).ToList()
            );

            Log($"Submitting PO: supplier={supplierId}, lines={request.Items.Count}, total={_estimatedTotal:C}");
            Logger.LogInformation("Creating PO draft for supplier {SupplierId} with {LineCount} line(s).", supplierId, request.Items.Count);

            var id = await PurchaseOrderService.CreateDraftAsync(request);
            Log($"PO created successfully. ID={id}");

            Nav.NavigateTo($"/purchase-orders/{id}");
        }
        catch (Exception ex)
        {
            _error = $"Failed to create purchase order: {ex.Message}";
            Log($"ERROR in HandleSubmit: {ex.Message}");
            Logger.LogError(ex, "Failed to create PO draft.");
            _submitting = false;
        }
    }

    private bool HasPartialInput =>
        !string.IsNullOrWhiteSpace(_newItem.ProductId) ||
        _newItem.Quantity > 1 ||
        _newItem.NegotiatedUnitCost > 0;

    private void Log(string message)
    {
        var entry = $"[{DateTime.Now:HH:mm:ss.fff}] {message}";
        _debugLog.Add(entry);
        Logger.LogDebug(entry);
    }

    private class CreatePurchaseOrderFormModel
    {
        [Required] public string SupplierId { get; set; } = string.Empty;
        public string? Notes { get; set; }
        public List<LineItemFormModel> Items { get; set; } = [];
    }

    private class LineItemFormModel
    {
        public string ProductId { get; set; } = string.Empty;
        public int Quantity { get; set; } = 1;
        public DateTime? ExpectedDeliveryDate { get; set; }
        public decimal NegotiatedUnitCost { get; set; }
    }
}